#!/bin/sh
BRANCH=$(git symbolic-ref --short HEAD)
if echo "$BRANCH" | grep -qE '^(main|master|develop)$'; then
echo "Skipping pre-push tests on protected branch: $BRANCH"
exit 0
fi
echo "Running unit tests before push on branch: $BRANCH"
npm test -- --watch=false --no-progress
if [ $? -ne 0 ]; then
echo ""
echo "Test failed. Push aborted."
echo "Fix the failing tests before pushing to remote."
exit 1
fi
echo "All tests passed. Pushing..."
exit 0
